{
  "ask-human": {
    "command": "ask-human",
    "args": ["--transport", "stdio"]
  },
  "ask-human-uvx": {
    "command": "uvx",
    "args": ["--from", "ask-human-now", "ask-human", "--transport", "stdio"]
  },
  "ask-human-local-dev": {
    "command": "python",
    "args": ["-m", "ask_human_now", "--transport", "stdio"],
    "cwd": ".",
    "env": {
      "PYTHONPATH": "./src"
    }
  }
}
